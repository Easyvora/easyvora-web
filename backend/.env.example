# ── SERVER ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── BASE DE DATOS (Hostinger MySQL) ─────────────────────────────
# En EasyPanel usa el host interno del contenedor MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=easyvora_db
DB_USER=easyvora_user
DB_PASS=tu_password_aqui

# ── EMAIL (Hostinger SMTP) ───────────────────────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@easyvoraproyect.com
SMTP_PASS=tu_password_de_email

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_una_cadena_muy_larga_y_aleatoria
JWT_EXPIRES=7d

# ── ADMIN ────────────────────────────────────────────────────────
# Genera el hash con: node scripts/generate-hash.js tu_password
ADMIN_EMAIL=admin@easyvoraproyect.com
ADMIN_PASS_HASH=$2b$10$ejemplo_hash_generado_con_generate-hash.js

# ── CORS ─────────────────────────────────────────────────────────
# En producción, pon la URL real de tu frontend (sin trailing slash)
FRONTEND_URL=https://tudominio.com
